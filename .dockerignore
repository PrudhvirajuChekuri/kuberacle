# Single build context (repo root) is shared by both images, so excludes are by
# specific subpath. Kept on purpose: web/ source, src/, configs/. The Chroma
# index is not baked into either image; the API pulls it from GCS at startup.

# Secrets / env (credentials are mounted at runtime, never copied in)
.env
**/.env.local

# Python
venv/
.venv/
**/__pycache__/
*.pyc
.pytest_cache/

# Node / Next build output (huge; regenerated inside the image)
web/node_modules/
web/.next/

# VCS and editor
.git/
.gitignore

# Tests and dev-only assets
tests/

# Raw and derived corpus data (not needed in an image; the index is pulled from GCS)
data/raw/
data/processed/
data/examples/
data/glossary/
data/includes/

# Untracked local-only files
HANDOFF.md
CLAUDE.md
design/

# Local-only artifacts and the release index tarball (never needed in an image;
# excluded to keep the build context small)
artifacts/
.claude/
.benchmarks/
chroma-index.tar.gz

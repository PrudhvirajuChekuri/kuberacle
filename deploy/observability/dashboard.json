{
  "displayName": "Kuberacle - serving",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 3,
        "height": 3,
        "widget": {
          "title": "Requests",
          "scorecard": {
            "timeSeriesQuery": {
              "outputFullDuration": true,
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/kuberacle_requests\" resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_DELTA",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 3,
        "yPos": 0,
        "width": 3,
        "height": 3,
        "widget": {
          "title": "Answer-cache hit rate",
          "scorecard": {
            "timeSeriesQuery": {
              "outputFullDuration": true,
              "timeSeriesFilterRatio": {
                "numerator": {
                  "filter": "metric.type=\"logging.googleapis.com/user/kuberacle_cache_requests\" resource.type=\"cloud_run_revision\" metric.label.\"cache_hit\"=\"true\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_DELTA",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                },
                "denominator": {
                  "filter": "metric.type=\"logging.googleapis.com/user/kuberacle_cache_requests\" resource.type=\"cloud_run_revision\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_DELTA",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              }
            },
            "gaugeView": {
              "lowerBound": 0.0,
              "upperBound": 1.0
            },
            "thresholds": [
              {
                "value": 0.5,
                "color": "RED",
                "direction": "BELOW"
              },
              {
                "value": 0.75,
                "color": "YELLOW",
                "direction": "BELOW"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 0,
        "width": 3,
        "height": 3,
        "widget": {
          "title": "Cost avoided by cache (30d)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_saved_cost_usd' | within 30d | align delta(30d) | every 30d | group_by [], [val: sum(value.kuberacle_saved_cost_usd)]"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 9,
        "yPos": 0,
        "width": 3,
        "height": 3,
        "widget": {
          "title": "Cold starts",
          "scorecard": {
            "timeSeriesQuery": {
              "outputFullDuration": true,
              "timeSeriesFilter": {
                "filter": "metric.type=\"logging.googleapis.com/user/kuberacle_requests\" resource.type=\"cloud_run_revision\" metric.label.\"cold_start\"=\"true\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_DELTA",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 3,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Requests by outcome",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_requests' | align delta(1d) | every 1d | group_by [metric.outcome], [val: sum(value.kuberacle_requests)]"
                },
                "plotType": "STACKED_BAR"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 3,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Request latency p95 (ms)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_request_latency_ms' | align delta(1d) | every 1d | group_by [], [p95: percentile(value.kuberacle_request_latency_ms, 95)]"
                },
                "plotType": "STACKED_BAR",
                "legendTemplate": "p95"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 7,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Daily cost: paid vs cache-saved (USD)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_request_cost_usd' | align delta(1d) | every 1d | group_by [], [paid: sum(value.kuberacle_request_cost_usd)]"
                },
                "plotType": "STACKED_BAR",
                "legendTemplate": "paid"
              },
              {
                "timeSeriesQuery": {
                  "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_saved_cost_usd' | align delta(1d) | every 1d | group_by [], [saved_by_cache: sum(value.kuberacle_saved_cost_usd)]"
                },
                "plotType": "STACKED_BAR",
                "legendTemplate": "saved by cache"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 7,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Cache: hits vs misses",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesQueryLanguage": "fetch cloud_run_revision | metric 'logging.googleapis.com/user/kuberacle_cache_requests' | align delta(1d) | every 1d | group_by [metric.cache_hit], [val: sum(value.kuberacle_cache_requests)]"
                },
                "plotType": "STACKED_BAR"
              }
            ]
          }
        }
      }
    ]
  }
}
